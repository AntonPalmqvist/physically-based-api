      "items": {
        "type": "number"
      },
      "example": [0, 0.351563, 1.85894],
      "minItems": 3,
      "maxItems": 3
    },
    "k": {
      "description": "Extinction coefficient (k) of each RGB color channel.",
      "type": "array",
      "items": {
        "type": "number"
      },
      "example": [6.59401, 2.08143, 1.49631],
      "minItems": 3,
      "maxItems": 3
