{
  "additionalProperties": false,
  "type": "object",
  "description": "Metadata",
  "properties": {
    "schemaVersion": {
      "description": "Schema version.",
      "type": "number",
      "example": 2.0
    },
    "updated": {
      "description": "Date updated, in YYYYMMDDHHmm format.",
      "type": "number",
      "example": 202512121608
    },
    "license": {
      "description": "License information.",
      "type": "string",
      "const": "CC0 1.0 Universal"
    },
    "origin": {
      "description": "URL to the source of this JSON file.",
      "type": "string",
      "pattern": "^https://api\\.physicallybased\\.info/v2"
    },
    "deprecated": {
      "description": "This will be set to true when this version of the API is deprecated and indicates that no more updates will be made. This helps visibility when using the data in different contexts.",
      "type": "boolean",
      "example": false
    }
  },
  "required": ["schemaVersion", "updated", "license", "origin", "deprecated"]
}
